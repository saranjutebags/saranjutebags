{
  "rewrites": [
    {
      "source": "/api/delhivery/:path*",
      "destination": "/api/delhivery.js"
    },
    {
      "source": "/api/create-order",
      "destination": "/api/create-order.js"
    },
    {
      "source": "/api/verify-payment",
      "destination": "/api/verify-payment.js"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
